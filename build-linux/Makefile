	$(MAKE) $(MAKESILENT) -f CMakeFiles/kalshi_backtest_tests.dir/build.make CMakeFiles/kalshi_backtest_tests.dir/tests/test_sweep_grid.cpp.s
.PHONY : tests/test_sweep_grid.cpp.s

